  "shichen": [
    {
      "id": "zi",
      "name": "子时",
      "alias": "夜半",
      "range": [
        23,
        1
      ],
      "poems": [
        {
          "line": "姑苏城外寒山寺，夜半钟声到客船",
          "source": "《枫桥夜泊》",
          "author": "张继",
          "dynasty": "唐",
          "why": "直书「夜半」,子时钟声。",
          "time_word": "夜半"
        },
        {
          "line": "更深月色半人家，北斗阑干南斗斜",
          "source": "《月夜》",
          "author": "刘方平",
          "dynasty": "唐",
          "why": "「更深」夜半,星斗横斜。",
          "time_word": "更深"
        }
      ]
    },
    {
      "id": "chou",
      "name": "丑时",
      "alias": "鸡鸣",
      "range": [
        1,
        3
      ],
      "poems": [
        {
          "line": "鸡声茅店月，人迹板桥霜",
          "source": "《商山早行》",
          "author": "温庭筠",
          "dynasty": "唐",
          "why": "「鸡声」即鸡鸣,残夜早行。",
          "time_word": "鸡声"
        },
        {
          "line": "风雨如晦，鸡鸣不已",
          "source": "《诗经·郑风·风雨》",
          "author": "佚名",
          "dynasty": "先秦",
          "why": "直书「鸡鸣」,丑时之名所自。",
          "time_word": "鸡鸣"
        }
      ]
    },
    {
      "id": "yin",
      "name": "寅时",
      "alias": "平旦",
      "range": [
        3,
        5
      ],
      "poems": [
        {
          "line": "平明寻白羽，没在石棱中",
          "source": "《塞下曲》",
          "author": "卢纶",
          "dynasty": "唐",
          "why": "「平明」即平旦,天将破晓。",
          "time_word": "平明"
        },
        {
          "line": "五更鼓角声悲壮，三峡星河影动摇",
          "source": "《阁夜》",
          "author": "杜甫",
          "dynasty": "唐",
          "why": "「五更」当寅时,残夜将尽。",
          "time_word": "五更"
        }
      ]
    },
    {
      "id": "mao",
      "name": "卯时",
      "alias": "日出",
      "range": [
        5,
        7
      ],
      "poems": [
        {
          "line": "日出江花红胜火，春来江水绿如蓝",
          "source": "《忆江南》",
          "author": "白居易",
          "dynasty": "唐",
          "why": "直书「日出」,卯时朝晖。",
          "time_word": "日出"
        },
        {
          "line": "东边日出西边雨，道是无晴却有晴",
          "source": "《竹枝词》",
          "author": "刘禹锡",
          "dynasty": "唐",
          "why": "直书「日出」,卯时晴雨。",
          "time_word": "日出"
        }
      ]
    },
    {
      "id": "chen",
      "name": "辰时",
      "alias": "食时",
      "range": [
        7,
        9
      ],
      "poems": [
        {
          "line": "青青园中葵，朝露待日晞",
          "source": "《长歌行》",
          "author": "佚名",
          "dynasty": "汉",
          "why": "「朝」露待晞,辰时向食。(替换「故人具鸡黍」:原句无直书时间词;主编裁定不用「晨起动征铎」以免与丑时「鸡声茅店月」同出一诗)",
          "time_word": "朝"
        },
        {
          "line": "朝辞白帝彩云间，千里江陵一日还",
          "source": "《早发白帝城》",
          "author": "李白",
          "dynasty": "唐",
          "why": "「朝」发之时,晨光在途。",
          "time_word": "朝"
        }
      ]
    },
    {
      "id": "si",
      "name": "巳时",
      "alias": "隅中",
      "range": [
        9,
        11
      ],
      "poems": [
        {
          "line": "酒困路长惟欲睡，日高人渴漫思茶",
          "source": "《浣溪沙·簌簌衣巾落枣花》",
          "author": "苏轼",
          "dynasty": "宋",
          "why": "「日高」人渴,近午未午的隅中。(替换「接天莲叶」:原句无直书时间词)",
          "time_word": "日高"
        },
        {
          "line": "日高睡足犹慵起，小阁重衾不怕寒",
          "source": "《香炉峰下新卜山居草堂初成偶题东壁》",
          "author": "白居易",
          "dynasty": "唐",
          "why": "「日高」睡足,巳时慵起。(替换「迟日江山丽」:原句无直书时间词)",
          "time_word": "日高"
        }
      ]
    },
    {
      "id": "wu",
      "name": "午时",
      "alias": "日中",
      "range": [
        11,
        13
      ],
      "poems": [
        {
          "line": "锄禾日当午，汗滴禾下土",
          "source": "《悯农》",
          "author": "李绅",
          "dynasty": "唐",
          "why": "直书「日当午」,日中之极。",
          "time_word": "日当午"
        },
        {
          "line": "日午独觉无余声，山童隔竹敲茶臼",
          "source": "《夏昼偶作》",
          "author": "柳宗元",
          "dynasty": "唐",
          "why": "直书「日午」,午睡方觉。(替换「绿树阴浓夏日长」:原句无直书时间词)",
          "time_word": "日午"
        }
      ]
    },
    {
      "id": "wei",
      "name": "未时",
      "alias": "日昳",
      "range": [
        13,
        15
      ],
      "poems": [
        {
          "line": "纸屏石枕竹方床，手倦抛书午梦长",
          "source": "《夏日登车盖亭》",
          "author": "蔡确",
          "dynasty": "宋",
          "why": "「午梦」长,日昳倦读。(替换「日长睡起」:原句无直书时间词。午梦为跨午/未界词,详见词表)",
          "time_word": "午梦"
        },
        {
          "line": "午枕花前簟欲流，日催红影上帘钩",
          "source": "《午枕》",
          "author": "王安石",
          "dynasty": "宋",
          "why": "「午枕」花前,日昳小憩。(替换「偷得浮生半日闲」:原句无直书时间词。午枕为跨午/未界词)",
          "time_word": "午枕"
        }
      ]
    },
    {
      "id": "shen",
      "name": "申时",
      "alias": "晡时",
      "range": [
        15,
        17
      ],
      "poems": [
        {
          "line": "返景入深林，复照青苔上",
          "source": "《鹿柴》",
          "author": "王维",
          "dynasty": "唐",
          "why": "「返景」入林,晡时斜光。",
          "time_word": "返景"
        },
        {
          "line": "过尽千帆皆不是，斜晖脉脉水悠悠",
          "source": "《望江南》",
          "author": "温庭筠",
          "dynasty": "唐",
          "why": "「斜晖」脉脉,日已西斜。(斜晖为跨申/酉界词)",
          "time_word": "斜晖"
        }
      ]
    },
    {
      "id": "you",
      "name": "酉时",
      "alias": "日入",
      "range": [
        17,
        19
      ],
      "poems": [
        {
          "line": "大漠孤烟直，长河落日圆",
          "source": "《使至塞上》",
          "author": "王维",
          "dynasty": "唐",
          "why": "「落日」圆,正是日入。",
          "time_word": "落日"
        },
        {
          "line": "一道残阳铺水中，半江瑟瑟半江红",
          "source": "《暮江吟》",
          "author": "白居易",
          "dynasty": "唐",
          "why": "「残阳」铺水,日入江上。",
          "time_word": "残阳"
        }
      ]
    },
    {
      "id": "xu",
      "name": "戌时",
      "alias": "黄昏",
      "range": [
        19,
        21
      ],
      "poems": [
        {
          "line": "夕阳西下，断肠人在天涯",
          "source": "《天净沙·秋思》",
          "author": "马致远",
          "dynasty": "元",
          "why": "「夕阳」西下,黄昏断肠。(替换《醉花阴》常规位:后者转为重阳彩蛋。夕阳为跨酉/戌界词)",
          "time_word": "夕阳"
        },
        {
          "line": "移舟泊烟渚，日暮客愁新",
          "source": "《宿建德江》",
          "author": "孟浩然",
          "dynasty": "唐",
          "why": "直书「日暮」,黄昏客愁。",
          "time_word": "日暮"
        },
        {
          "line": "东篱把酒黄昏后，有暗香盈袖",
          "source": "《醉花阴》",
          "author": "李清照",
          "dynasty": "宋",
          "why": "「黄昏」把酒,重阳咏怀。此为重阳彩蛋,平日不出现,仅重阳当天顶替戌时常规句。",
          "time_word": "黄昏",
          "festival": "重阳"
        }
      ]
    },
    {
      "id": "hai",
      "name": "亥时",
      "alias": "人定",
      "range": [
        21,
        23
      ],
      "poems": [
        {
          "line": "奄奄黄昏后，寂寂人定初",
          "source": "《孔雀东南飞》",
          "author": "佚名",
          "dynasty": "汉",
          "why": "直书「人定」,亥时初静。",
          "time_word": "人定"
        },
        {
          "line": "夜阑更秉烛，相对如梦寐",
          "source": "《羌村三首》",
          "author": "杜甫",
          "dynasty": "唐",
          "why": "「夜阑」秉烛,人定灯前。(替换「天阶夜色凉如水」:原句无直书时间词。夜阑为跨亥/子界词)",
          "time_word": "夜阑"
        }
      ]
    }
  ]
